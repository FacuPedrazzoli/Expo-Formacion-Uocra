  "talks": [
    { "id": "tal-001", "title": "Charla Inaugural: El futuro de la construcción en Argentina", "description": "Apertura oficial de Expo Formación UOCRA 2026. Palabras de autoridades gremiales y presentación de las tendencias del sector para los próximos años.", "speaker": "Autoridades UOCRA", "startTime": "09:00", "endTime": "10:00", "room": "Salón Principal" },
    { "id": "tal-002", "title": "Normativas de Seguridad Laboral 2026", "description": "Actualización sobre las nuevas normas de seguridad en obras de construcción. Higiene, prevención de accidentes y equipamiento de protección personal.", "speaker": "Dr. Carlos López", "startTime": "10:30", "endTime": "11:30", "room": "Aula 1" },
    { "id": "tal-003", "title": "Tecnologías BIM en proyectos de construcción", "description": "Introducción a la Modelación de Información de Edificios. Cómo implementar BIM en obras de infraestructura y vivienda.", "speaker": "Ing. María García", "startTime": "10:30", "endTime": "11:30", "room": "Aula 2" },
    { "id": "tal-004", "title": "Oportunidades de empleo en el sector construcción", "description": "Panel con empresas del sector hablando sobre demanda de trabajadores especializados. Requisitos, beneficios y cómo aplicar.", "speaker": "Panel de Empresas", "startTime": "12:00", "endTime": "13:00", "room": "Salón Principal" },
    { "id": "tal-005", "title": "Introducción a la albañilería profesional", "description": "Técnicas actualizadas de albañilería. Materiales, herramientas y procedimientos para obras de calidad.", "speaker": "Of. Juan Pérez", "startTime": "14:00", "endTime": "15:00", "room": "Aula 1" },
    { "id": "tal-006", "title": "Electricidad residencial y comercial", "description": "Fundamentos de instalación eléctrica. Normas IRAM, cableado y sistemas de protección para edificios.", "speaker": "Ing. Roberto Sánchez", "startTime": "14:00", "endTime": "15:00", "room": "Aula 2" },
    { "id": "tal-007", "title": "Construcción sostenible y eficiencia energética", "description": "Materiales ecológicos y técnicas de construcción verde. Certificaciones LEED y estrategias de ahorro energético.", "speaker": "Dra. Ana Martínez", "startTime": "15:30", "endTime": "16:30", "room": "Aula 1" },
    { "id": "tal-008", "title": "Manejo de maquinaria pesada", "description": "Operación segura de excavadoras, cargadores y retroexcavadoras. Mantenimiento preventivo y productividad.", "speaker": "Tec. Luis Torres", "startTime": "09:00", "endTime": "10:30", "room": "Aula 1" },
    { "id": "tal-009", "title": "Gestión de obras y presupuestos", "description": "Administración de proyectos de construcción. Control de costos, cronograma y recursos humanos.", "speaker": "Ing. Pablo Fernández", "startTime": "09:00", "endTime": "10:00", "room": "Aula 2" },
    { "id": "tal-010", "title": "Herramientas eléctricas: mantenimiento y seguridad", "description": "Uso correcto de herramientas eléctricas. Mantenimiento, cuidados y prevención de accidentes.", "speaker": "Of. Miguel Ruiz", "startTime": "10:30", "endTime": "11:30", "room": "Aula 1" },
    { "id": "tal-011", "title": "Panel: Mujeres en la construcción", "description": "Experiencias y testimonios de mujeres que trabajan en el sector construcción. Desafíos, logros y oportunidades.", "speaker": "Panel de Mujeres UOCRA", "startTime": "11:00", "endTime": "12:30", "room": "Salón Principal" },
    { "id": "tal-012", "title": "Soldadura profesional", "description": "Técnicas de soldadura para construcción. Soldadura MIG, TIG y arco manual. Materiales y equipos.", "speaker": "Of. Diego Herrera", "startTime": "14:00", "endTime": "15:30", "room": "Aula 1" },
    { "id": "tal-013", "title": "Carpintería de obra", "description": "Técnicas de carpintería para construcción. Estructuras de madera, encofrados y terminaciones.", "speaker": "Of. Ricardo Acosta", "startTime": "14:00", "endTime": "15:00", "room": "Aula 2" },
    { "id": "tal-014", "title": "Primeros auxilios en obra", "description": "Capacitación en primeros auxilios especializados para accidentes de construcción. RCP, emergencias y evacuación.", "speaker": "Dr. Jorge Muñoz", "startTime": "15:30", "endTime": "17:00", "room": "Salón Principal" },
    { "id": "tal-015", "title": "Instalaciones sanitarias modernas", "description": "Nuevas técnicas en instalaciones de agua fría, caliente y desagües. Materiales y normativas actualizadas.", "speaker": "Ing. Sergio Vega", "startTime": "10:30", "endTime": "11:30", "room": "Aula 3" },
    { "id": "tal-016", "title": "Pintura profesional de edificios", "description": "Técnicas de pintura industrial y decorativa. Preparación de superficies y acabados de calidad.", "speaker": "Of. Marcelo Córdoba", "startTime": "14:00", "endTime": "15:00", "room": "Aula 3" },
    { "id": "tal-017", "title": "Aislamiento térmico y acústico", "description": "Materiales y técnicas para mejorar la eficiencia energética y el confort en viviendas.", "speaker": "Ing. Laura Díaz", "startTime": "15:30", "endTime": "16:30", "room": "Aula 3" },
    { "id": "tal-018", "title": "Estructuras metálicas: montaje y soldadura", "description": "Técnicas de armado y unión de estructuras metálicas en obras de gran escala.", "speaker": "Ing. Fernando Ríos", "startTime": "09:00", "endTime": "10:30", "room": "Aula 2" },
    { "id": "tal-019", "title": "Trabajo en altura:", "description": "Seguridad y técnicas de trabajo en alturas. Uso de andamios, arneses y líneas de vida.", "speaker": "Tec. Adrián Ojeda", "startTime": "10:30", "endTime": "12:00", "room": "Aula 4" },
    { "id": "tal-020", "title": "Demoliciones controladas", "description": "Técnicas seguras para demolición de estructuras. Planificación, ejecución y gestión de residuos.", "speaker": "Ing. Gustavo Peña", "startTime": "14:00", "endTime": "15:00", "room": "Aula 4" },
    { "id": "tal-021", "title": "Hormigón: dosificación y colocación", "description": "Fundamentos del hormigón fresco y endurecido. Dosificación, transporte y colocación en obra.", "speaker": "Ing. Claudio Mendoza", "startTime": "15:30", "endTime": "16:30", "room": "Aula 4" },
    { "id": "tal-022", "title": "Automatización residencial", "description": "Introducción a sistemas domóticos. Control de iluminación, climatización y seguridad.", "speaker": "Ing. Daniel Chavez", "startTime": "09:00", "endTime": "10:00", "room": "Aula 5" },
    { "id": "tal-023", "title": "Ventilación y aire acondicionado", "description": "Sistemas de climatización residenciales y comerciales. Cálculo de carga térmica.", "speaker": "Tec. Martín Sosa", "startTime": "10:30", "endTime": "11:30", "room": "Aula 5" },
    { "id": "tal-024", "title": "Impermeabilizaciones", "description": "Técnicas de impermeabilización en cubiertas, tanques y subterráneos. Materiales y aplicaciones.", "speaker": "Ing. Natalia Reyes", "startTime": "14:00", "endTime": "15:00", "room": "Aula 5" },
    { "id": "tal-025", "title": "Colocación de pisos y revestimientos", "description": "Técnicas de colocación de cerámicos, porcelanatos y piedras. Niveles y junquinas.", "speaker": "Of. Carlos Guzman", "startTime": "15:30", "endTime": "16:30", "room": "Aula 5" },
    { "id": "tal-026", "title": "Seguridad vial en zonas de obra", "description": "Señalización y gestión del tránsito en áreas de trabajo vial. Normativas y buenas prácticas.", "speaker": "Ing. Alejandro Barra", "startTime": "09:00", "endTime": "10:00", "room": "Aula 6" },
    { "id": "tal-027", "title": "Excavaciones y movimiento de suelos", "description": "Técnicas de excavación, nivelación y compactación de suelos. Equipos y seguridad.", "speaker": "Ing. Eduardo Ruiz", "startTime": "10:30", "endTime": "11:30", "room": "Aula 6" },
    { "id": "tal-028", "title": "Techumbres y cubierta", "description": "Sistemas de cubierta inclinada y plana. Estructura, aislación y membrana.", "speaker": "Of. Jorge Ibáñez", "startTime": "14:00", "endTime": "15:00", "room": "Aula 6" },
    { "id": "tal-029", "title": "Cerramientos y aberturas de aluminio", "description": "Ventanas, puertas y frente de vidro. Perfiles, herrajes y vidrios.", "speaker": "Tec. Alberto Nieva", "startTime": "15:30", "endTime": "16:30", "room": "Aula 6" },
    { "id": "tal-030", "title": "Cierre: palabras de agradecimiento", "description": "Cierre oficial del evento. Reconocimientos y próximos pasos para Expo Formación UOCRA.", "speaker": "Autoridades UOCRA", "startTime": "17:00", "endTime": "18:00", "room": "Salón Principal" }
  ],
